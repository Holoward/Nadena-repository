{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/var/nadena/nadena.db"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "Nadena",
    "Audience": "NadenaUsers",
    "ExpiryInMinutes": 60
  },
  "NadenaSettings": {
    "JwtKey": "${JWT_SECRET_KEY}",
    "JwtIssuer": "Nadena",
    "JwtAudience": "NadenaUsers",
    "JwtExpireMinutes": "60",
    "StripeSecretKey": "${STRIPE_SECRET_KEY}",
    "StripeWebhookSecret": "${STRIPE_WEBHOOK_SECRET}",
    "PayPalClientId": "${PAYPAL_CLIENT_ID}",
    "PayPalClientSecret": "${PAYPAL_CLIENT_SECRET}",
    "PayPalMode": "live",
    "PlatformFeePercent": 25,
    "FrontendUrl": "https://nadena.com",
    "SmtpHost": "${SMTP_HOST}",
    "SmtpPort": 587,
    "SmtpUser": "${SMTP_USER}",
    "SmtpPassword": "${SMTP_PASSWORD}",
    "SmtpFromEmail": "noreply@nadena.com",
    "SmtpFromName": "Nadena",
    "AdminEmail": "admin@nadena.com",
    "GroqApiKey": "${GROQ_API_KEY}",
    "GroqModel": "llama3-8b-8192"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "nadena.com"
}
